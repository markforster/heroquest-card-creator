{
  "name": "@markforster/heroquest-card-creator",
  "version": "0.5.3",
  "description": "Browser-based tool to design HeroQuest-style cards with accurate layouts, asset library, and PNG export — runs locally.",
  "author": "Mark Forster (markforster)",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/markforster/heroquest-card-creator"
  },
  "homepage": "https://github.com/markforster/heroquest-card-creator",
  "bugs": {
    "url": "https://github.com/markforster/heroquest-card-creator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "heroquest",
    "card",
    "cards",
    "card-creator",
    "card-maker",
    "homebrew",
    "tabletop",
    "boardgame",
    "rpg",
    "fantasy",
    "custom-cards",
    "printable",
    "deck",
    "generator",
    "editor"
  ],
  "packageManager": "npm@10.8.1",
  "bin": {
    "heroquest-card-creator": "bin/heroquest-card-creator.js"
  },
  "files": [
    "out/**",
    "bin/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate:embedded-assets": "node scripts/generate-embedded-assets.cjs",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "predev": "npm run generate:embedded-assets && node scripts/copy-zip-worker.cjs",
    "prepack": "cp README.npm.md README.md && npm run build && npm run verify:out",
    "prebuild": "npm run generate:embedded-assets && node scripts/copy-zip-worker.cjs",
    "build": "NODE_ENV=production npm run verify:env && NODE_ENV=production next build",
    "build:download": "npm run build && node scripts/package-download.js",
    "start": "next start",
    "lint": "next lint",
    "verify:env": "node scripts/verify-env.js",
    "verify:out": "node scripts/verify-out.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:report": "jest --coverage --reporters=default --reporters=jest-html-reporter",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve:out": " npx serve ./out -l 3000",
    "tauri": "tauri",
    "tauri:icons": "tauri icon public/assets/web-app-manifest-512x512.png",
    "sync:tauri-version": "node scripts/sync-tauri-version.cjs",
    "pretauri:build": "npm run sync:tauri-version",
    "tauri:build": "npm run build && npm run tauri:icons && tauri build",
    "postpack": "git checkout -- README.md",
    "publish:npm": "npm publish",
    "publish:gh": "npm publish --registry https://npm.pkg.github.com",
    "publish:all": "npm run publish:npm && npm run publish:gh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^6.0.1",
    "@zip.js/zip.js": "^2.8.21",
    "chalk": "^4.1.2",
    "inquirer": "^9.3.7",
    "mime": "^3.0.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@next/third-parties": "^16.1.0",
    "@react-three/fiber": "^8.16.8",
    "@svgr/webpack": "^8.1.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.182.0",
    "bootstrap": "^5.3.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "lucide-react": "^0.561.0",
    "next": "14.2.15",
    "prettier": "^3.6.2",
    "react": "^18",
    "react-colorful": "^5.6.1",
    "react-dom": "^18",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.13.0",
    "react-snowfall": "^2.2.0",
    "three": "^0.167.1",
    "typescript": "^5"
  },
  "jest-html-reporter": {
    "outputPath": "artefacts/reports/test-report.html",
    "pageTitle": "Test Report",
    "includeConsoleLog": true,
    "includeFailureMsg": true
  }
}
